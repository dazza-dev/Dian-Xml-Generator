{% apply spaceless %}<?xml version="1.0" encoding="UTF-8" standalone="no"?>{% endapply %}
<NominaIndividual xmlns="dian:gov:co:facturaelectronica:NominaIndividual"
                  xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:ds="http://www.w3.org/2000/09/xmldsig#"
                  xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
                  xmlns:xades="http://uri.etsi.org/01903/v1.3.2#"
                  xmlns:xades141="http://uri.etsi.org/01903/v1.4.1#"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  SchemaLocation=""
                  xsi:schemaLocation="dian:gov:co:facturaelectronica:NominaIndividual NominaIndividualElectronicaXSD.xsd">
    {# UBLExtensions #}
    {% include 'Components/ubl-extensions-payroll.xml.twig' %}
    <Novedad CUNENov="A">false</Novedad>



    <cbc:IssueDate>{{ issue_date }}</cbc:IssueDate>
    <cbc:IssueTime>{{ issue_time }}</cbc:IssueTime>
    {% if due_date %}
    <cbc:DueDate>{{ due_date }}</cbc:DueDate>
    {% endif %}
    <cbc:InvoiceTypeCode>{{ document_type.code }}</cbc:InvoiceTypeCode>
    {% if note %}
    <cbc:Note>{{ note }}</cbc:Note>
    {% endif %}
    <cbc:DocumentCurrencyCode listAgencyID="6" listAgencyName="United Nations Economic Commission for Europe" listID="ISO 4217 Alpha">{{ currency.code }}</cbc:DocumentCurrencyCode>
    <cbc:LineCountNumeric>{{ line_items|length }}</cbc:LineCountNumeric>
    {# OrderReference #}
    {% if order_reference %}
    <cac:OrderReference>
        <cbc:ID>{{ order_reference.number }}</cbc:ID>
    </cac:OrderReference>
    {% endif %}
    {# AccountingSupplierParty #}
    {% include 'Components/accounting.xml.twig' with {
        'node': 'AccountingSupplierParty',
        'entity': company,
        'show_merchant_registration': true,
        'show_physical_location': true
    } %}
    {# AccountingCustomerParty #}
    {% include 'Components/accounting.xml.twig' with {
        'node': 'AccountingCustomerParty',
        'entity': customer,
        'show_merchant_registration': false,
        'show_physical_location': false
    } %}
    {# PaymentMeans #}
    {% include 'Components/payment-means.xml.twig' %}
    {# PrePaidPayment #}
    {% include 'Components/prepaid-payment.xml.twig' %}
    {# AllowanceCharges #}
    {% include 'Components/allowance-charges.xml.twig' with {
        'allowance_charges': allowance_charges
    } %}
    {# TaxTotals #}
    {% include 'Components/tax-totals.xml.twig' with {
        'taxes': taxes,
    } %}
    {# LegalMonetaryTotal #}
    {% include 'Components/legal-monetary-total.xml.twig' with {
        'node': 'LegalMonetaryTotal',
    } %}
    {# InvoiceLines #}
    {% include 'Components/line-items.xml.twig' with {
        'node': 'InvoiceLine',
        'nodeQty': 'InvoicedQuantity'
    } %}
</NominaIndividual>
